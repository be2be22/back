# استفاده از نسخه سبک و سریع نود جی‌اس
FROM node:18-alpine

# ایجاد یک پوشه برای برنامه
WORKDIR /app

# کپی کردن فایل package.json برای نصب کتابخانه‌ها
COPY package*.json ./

# نصب کتابخانه‌ها
RUN npm install

# کپی کردن بقیه فایل‌های پروژه (فایل server.js)
COPY . .

# باز کردن پورت 8080 (پورتی که کد ما روی آن گوش می‌دهد)
EXPOSE 8080

# دستوری که سرور را روشن می‌کند
CMD ["npm", "start"]
